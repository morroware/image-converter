# The Castle Fun Center — Image Toolkit
# Root .htaccess: harden access + enable compression/caching for assets.

Options -Indexes

# -----------------------------------------------------------------------------
# Block direct access to source / config / tmp files.
# -----------------------------------------------------------------------------
<FilesMatch "^(config\.php|config\.example\.php|bootstrap\.php|\.installed)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Old Apache 2.2 compatibility.
<IfModule !mod_authz_core.c>
    <FilesMatch "^(config\.php|config\.example\.php|bootstrap\.php|\.installed)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# -----------------------------------------------------------------------------
# Compression
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml application/xml
</IfModule>

# -----------------------------------------------------------------------------
# Caching static assets aggressively.
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                    "access plus 7 days"
    ExpiresByType application/javascript      "access plus 7 days"
    ExpiresByType image/svg+xml               "access plus 30 days"
    ExpiresByType image/png                   "access plus 30 days"
    ExpiresByType image/jpeg                  "access plus 30 days"
    ExpiresByType image/webp                  "access plus 30 days"
    ExpiresByType image/avif                  "access plus 30 days"
    ExpiresByType font/woff2                  "access plus 30 days"
</IfModule>

# -----------------------------------------------------------------------------
# Safety headers.
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
